# Configuration Firebase (connexion Google + email/mot de passe).
# Copiez ce fichier en .env.local pour du développement local, et renseignez
# les mêmes valeurs dans Vercel : Project Settings → Environment Variables.
#
# Où trouver ces valeurs :
# 1. https://console.firebase.google.com → créez un projet
# 2. Authentication → Sign-in method → activez "Google" et "Email/Password"
# 3. Authentication → Settings → Authorized domains → ajoutez votre domaine
#    Vercel (ex: frigomind.vercel.app)
# 4. Project Settings → General → "Vos applications" → ajoutez une app Web
#    → copiez les valeurs du firebaseConfig ci-dessous.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Page admin cachée (/admin) : tableau de bord technique + gestion des
# données locales, accessible uniquement au compte connecté avec cette
# adresse email exacte. Laissez vide pour désactiver complètement la page
# (aucun compte n'y aura accès).
VITE_ADMIN_EMAIL=

# Firebase Admin SDK (fonctions serverless dans /api/admin/*, jamais exposé au
# navigateur — pas de préfixe VITE_) : liste des comptes + activation/
# désactivation, utilisé par l'onglet "Utilisateurs" de la page admin.
#
# Où trouver ces valeurs :
# 1. https://console.firebase.google.com → votre projet
# 2. Paramètres du projet (⚙️) → Comptes de service
# 3. "Générer une nouvelle clé privée" → télécharge un fichier JSON
# 4. Dans ce JSON : project_id → FIREBASE_PROJECT_ID,
#    client_email → FIREBASE_CLIENT_EMAIL, private_key → FIREBASE_PRIVATE_KEY
#    (collez la valeur telle quelle, guillemets et \n littéraux compris —
#    api/_lib/admin.js les convertit automatiquement).
#
# ⚠️ Cette clé donne un accès administrateur complet à votre projet Firebase.
# Ne la commitez jamais, gardez-la uniquement dans les variables d'environnement
# Vercel (Project Settings → Environment Variables, pas dans .env.local si ce
# fichier risque d'être partagé).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
